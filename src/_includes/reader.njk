{% extends "base.njk" %}

{% block extra_css %}
<style>
  .reader {
    /* Padding and sizing handled by layout.css grid */
    margin: 0 auto;
  }
  
  /* PROFESSIONAL EDITORIAL TYPOGRAPHY */
  body .reader .episode-body {
    line-height: 1.75 !important;
    font-size: 19px !important; /* Professional mobile base */
    color: var(--text-primary) !important;
    font-family: 'Crimson Pro', serif !important;
    letter-spacing: -0.01em;
  }

  @media (min-width: 1024px) {
    body .reader .episode-body {
        font-size: 21px !important; /* Professional web size */
    }
  }

  /* Headers */
  body .reader .episode-body h3 {
    font-size: 24px !important;
    margin-top: 48px !important;
    margin-bottom: 24px !important;
    color: var(--ink) !important;
    font-weight: 700 !important;
  }

  .ep-nav-section {
    margin-top: 80px;
    padding-bottom: 80px;
    display: block !important;
  }

  .ep-nav-divider {
    height: 1px;
    background: var(--border-base);
    margin-bottom: 40px;
  }

  .ep-nav-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .ep-nav-btn {
    display: flex;
    flex-direction: column;
    padding: 20px;
    background: var(--bg-surface);
    border: 1px solid var(--border-base);
    border-radius: 12px;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .ep-nav-btn:hover {
    border-color: var(--ink);
    background: var(--bg-raised);
  }

  .ep-nav-btn.next {
    text-align: right;
    align-items: flex-end;
  }

  .ep-nav-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .ep-nav-title {
    font-family: 'Noto Serif KR', serif;
    font-size: 16px;
    color: var(--ink);
    font-weight: 700;
  }

  .ep-nav-placeholder {
    visibility: hidden;
  }

  @media (max-width: 640px) {
    .ep-nav-links {
      grid-template-columns: 1fr;
    }
  }
</style>
{% endblock %}

{% block content %}
<main class="main-layout">
  {% include "partials/sidebar.njk" %}
  
  {% set collectionName = lang + "Episodes" %}
  {% set navPages = collections[collectionName] %}
  {% set previousPost = navPages | getPreviousCollectionItem %}
  {% set nextPost = navPages | getNextCollectionItem %}

  <article class="reader">
    <div class="episode-label">{{ 'hero_volume' | t(lang) }}</div>
    <h1 class="episode-title">{{ title }}</h1>
    
    <div class="reading-time">
      <span style="color: var(--ink);">●</span> {% if wordCount %}{{ (wordCount / 200) | round }}{% else %}5{% endif %} {{ 'reading_time_suffix' | t(lang) }}
    </div>
    
    <div class="episode-body" id="episode-body">
      {{ content | safe }}
    </div>

    <div class="ep-nav-section">
      <div class="ep-nav-divider"></div>
      <div class="ep-nav-links">
        {% if previousPost %}
        <a href="{{ previousPost.url }}" class="ep-nav-btn prev">
          <span class="ep-nav-label">{{ 'ep_prev' | t(lang) }}</span>
          <span class="ep-nav-title">{{ previousPost.data.title }}</span>
        </a>
        {% else %}
        <div class="ep-nav-placeholder"></div>
        {% endif %}

        {% if nextPost %}
        <a href="{{ nextPost.url }}" class="ep-nav-btn next">
          <span class="ep-nav-label">{{ 'ep_next' | t(lang) }}</span>
          <span class="ep-nav-title">{{ nextPost.data.title }}</span>
        </a>
        {% endif %}
      </div>
    </div>
  </article>
  
  {% include "partials/right-panel.njk" %}
</main>
{% endblock %}
