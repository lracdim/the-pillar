{% extends "base.njk" %}

{% block content %}
<section class="hero">
  <h1 class="hero-title">{{ site.name }}</h1>
  <p class="hero-subtitle">{{ 'hero_subtitle' | t(lang) }}</p>
  
  <div class="hero-stats">
    <div class="stat-item">
      <div class="stat-num" id="total-readers">-</div>
      <div class="stat-label">{{ 'stat_readers' | t(lang) }}</div>
    </div>
    <div class="stat-item">
      <div class="stat-num" id="total-visitors">-</div>
      <div class="stat-label">{{ 'stat_visitors' | t(lang) }}</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">{{ episodes | length }}</div>
      <div class="stat-label">{{ 'stat_episodes' | t(lang) }}</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">1</div>
      <div class="stat-label">{{ 'stat_kingdoms' | t(lang) }}</div>
    </div>
  </div>
</section>

<div class="home-episode-grid">
  {% for ep in episodes %}
  <a href="/{{ lang }}/{{ ep.slug }}/" class="episode-card" data-slug="{{ ep.slug }}" data-free="{{ ep.free }}">
    <div class="episode-card-num">{{ 'sidebar_episodes' | t(lang) }} {{ ep.episode }}</div>
    <h2 class="episode-card-title">{{ ep.titles[lang] }}</h2>
    <p class="episode-card-excerpt">{{ ep.excerpt[lang] }}</p>
    {% if ep.free %}
    <span class="episode-card-badge">{{ 'sidebar_free_preview' | t(lang) }}</span>
    {% else %}
    <span class="episode-card-badge">🔒 {{ 'sidebar_locked' | t(lang) }}</span>
    {% endif %}
  </a>
  {% endfor %}
</div>
{% endblock %}
