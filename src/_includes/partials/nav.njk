<nav class="navbar">
  <a href="/{{ lang }}/" class="navbar-logo">
    {{ site.name }}<span class="navbar-logo-sub">{{ site.nameKo }} · 柱</span>
  </a>
  
  <div class="navbar-links">
    <a href="/{{ lang }}/" {% if page.url == '/' + lang + '/' %}class="active"{% endif %}>{{ 'nav_read' | t(lang) }}</a>
    <a href="/{{ lang }}/about/" {% if '/about/' in page.url %}class="active"{% endif %}>{{ 'nav_about' | t(lang) }}</a>
    <a href="/{{ lang }}/characters/" {% if '/characters/' in page.url %}class="active"{% endif %}>{{ 'nav_characters' | t(lang) }}</a>
  </div>
  
  <div class="navbar-actions">
    <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
      <span class="icon-sun">☀️</span>
      <span class="icon-moon">🌙</span>
    </button>
    <select id="lang-select" class="lang-select">
      {% for l in site.availableLangs %}
      <option value="{{ l }}" {% if l == lang %}selected{% endif %}>
        {% if l == 'ko' %}{{ ko.lang_ko }}{% elif l == 'tl' %}{{ tl.lang_tl }}{% else %}{{ en.lang_en }}{% endif %}
      </option>
      {% endfor %}
    </select>
    
    <div id="nav-auth-guest">
      <button class="btn-signin" id="nav-signin-btn">{{ 'nav_signin' | t(lang) }}</button>
      <button class="btn-signup" id="nav-signup-btn">{{ 'nav_signup' | t(lang) }}</button>
    </div>
    
    <div id="nav-auth-user" class="hidden">
      <span id="nav-username"></span>
      <button class="btn-signout" id="nav-signout-btn">{{ 'nav_signout' | t(lang) }}</button>
    </div>
    
    <button class="hamburger" id="hamburger-btn">☰</button>
  </div>
</nav>

<div class="mobile-menu" id="mobile-menu">
  <a href="/{{ lang }}/">{{ 'nav_read' | t(lang) }}</a>
  <a href="/{{ lang }}/about/">{{ 'nav_about' | t(lang) }}</a>
  <a href="/{{ lang }}/characters/">{{ 'nav_characters' | t(lang) }}</a>
  <div id="mobile-auth-guest">
    <button class="btn-signin" id="mobile-nav-signin-btn">{{ 'nav_signin' | t(lang) }}</button>
    <button class="btn-signup" id="mobile-nav-signup-btn">{{ 'nav_signup' | t(lang) }}</button>
  </div>
  <div id="mobile-auth-user" class="hidden">
    <span id="mobile-username"></span>
    <button class="btn-signout" id="mobile-signout-btn">{{ 'nav_signout' | t(lang) }}</button>
  </div>
</div>
