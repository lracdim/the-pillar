<footer class="footer">
  <div class="footer-content">
    <div class="footer-top">
      <div class="footer-info">
        <a href="/{{ lang }}/" class="footer-logo">
          {{ site.name }}<span class="navbar-logo-sub">{{ site.nameKo }} · 柱</span>
        </a>
        <p class="footer-tagline">
          {{ site.tagline }}
        </p>
      </div>
      
      <div class="footer-links">
        <div class="footer-link-group">
          <span class="footer-link-title">{% if lang == 'ko' %}탐색{% else %}Navigate{% endif %}</span>
          <a href="/{{ lang }}/">{% if lang == 'ko' %}{{ ko.nav_read }}{% else %}{{ en.nav_read }}{% endif %}</a>
          <a href="/about/">{% if lang == 'ko' %}{{ ko.nav_about }}{% else %}{{ en.nav_about }}{% endif %}</a>
          <a href="/characters/">{% if lang == 'ko' %}{{ ko.nav_characters }}{% else %}{{ en.nav_characters }}{% endif %}</a>
        </div>
        
        <div class="footer-link-group">
          <span class="footer-link-title">{% if lang == 'ko' %}커뮤니티{% else %}Community{% endif %}</span>
          <a href="https://twitter.com/thepillar" target="_blank" rel="noopener">Twitter</a>
          <a href="https://discord.gg/thepillar" target="_blank" rel="noopener">Discord</a>
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <div class="footer-copyright">
        &copy; 2024 {{ site.name }}. {% if lang == 'ko' %}모든 권리 보유.{% else %}All rights reserved.{% endif %}
      </div>
      <div class="footer-built">
        {% if lang == 'ko' %}역사적인 여정.{% else %}A historical journey.{% endif %}
      </div>
    </div>
  </div>
</footer>
