<footer class="footer">
  <div class="footer-content">
    <div class="footer-top">
      <div class="footer-info">
        <a href="/{{ lang }}/" class="footer-logo">
          {{ site.name }}<span class="navbar-logo-sub">{{ site.nameKo }} · 柱</span>
        </a>
        <p class="footer-tagline">
          {{ site.tagline }}
        </p>
      </div>
      
      <div class="footer-links">
        <div class="footer-link-group">
          <span class="footer-link-title">{{ 'nav_navigate' | t(lang) }}</span>
          <a href="/{{ lang }}/">{{ 'nav_read' | t(lang) }}</a>
          <a href="/{{ lang }}/about/">{{ 'nav_about' | t(lang) }}</a>
          <a href="/{{ lang }}/characters/">{{ 'nav_characters' | t(lang) }}</a>
        </div>
        
        <div class="footer-link-group">
          <span class="footer-link-title">{{ 'nav_community' | t(lang) }}</span>
          <a href="https://twitter.com/thepillar" target="_blank" rel="noopener">Twitter</a>
          <a href="https://discord.gg/thepillar" target="_blank" rel="noopener">Discord</a>
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <div class="footer-copyright">
        &copy; 2024 {{ site.name }}. {{ 'footer_rights' | t(lang) }}
      </div>
      <div class="footer-built">
        {{ 'footer_built' | t(lang) }}
      </div>
    </div>
  </div>
</footer>
